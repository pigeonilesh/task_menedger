<Window x:Class="task_menedger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:task_menedger"
        mc:Ignorable="d"
        Title="MainWindow" Height="800" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <TextBox Grid.Row="0"
                 Name="Input_text"
                 Height="80"
                 TextAlignment="Center"
                 Text="Введите задачу"
                 FontSize="28"
                 VerticalContentAlignment="Center"
                 BorderBrush="DarkOliveGreen"
                 BorderThickness="5"
                 Margin="10"/>

        <ComboBox Grid.Row="1"
                  Height="50"
                  Margin="10"
                  Name="Choose_Priority">
            <TextBlock FontSize="18">Высокий</TextBlock>
            <TextBlock FontSize="18">Средний</TextBlock>
            <TextBlock FontSize="18">Низкий</TextBlock>
        </ComboBox>

        <Button Name="Add_tasks"
                Grid.Row="2"
                Margin="10"
                Height="50"
                HorizontalAlignment="Center"
                Width="300"
                Content="Добавить задачу"
                FontSize="18"
                Foreground="White"
                Background="DarkOliveGreen"/>

        <ListBox Grid.Row="3"
                 Height="200"
                 Margin="10"
                 Name="tasks_list"
                 FontSize="20"
                 BorderBrush="DarkOliveGreen"
                 BorderThickness="5">
        </ListBox>

        <GroupBox Grid.Row="4"
                  Header="Фильтры"
                  Height="80"
                  Margin="10"
                  Padding="10">
            <StackPanel Orientation="Horizontal"
                        Name="filtr_Priority"> 
                <RadioButton Name="Hight_Priority"/>
                <RadioButton Name="Medium_Priority"/>
                <RadioButton Name="Low_Priority"/>
            </StackPanel>
        </GroupBox>

        <Button Name="delete_tasks"
                Grid.Row="5"
                Margin="10"
                Height="50"
                HorizontalAlignment="Center"
                Width="300"
                Content="Удалить выбранные задачи"
                FontSize="18"
                Foreground="White"
                Background="DarkOliveGreen"/>

        <Button Name="complete_tasks"
                Grid.Row="6"
                Margin="10"
                Height="50"
                HorizontalAlignment="Center"
                Width="300"
                Content="Отметить выполненной"
                FontSize="18"
                Foreground="White"
                Background="DarkOliveGreen"/>

        <Button Name="sort_tasks"
                Grid.Row="7"
                Margin="10"
                Height="50"
                HorizontalAlignment="Center"
                Width="300"
                Content="Сортировать по приоритету"
                FontSize="18"
                Foreground="White"
                Background="DarkOliveGreen"/>
    </Grid>
</Window>
