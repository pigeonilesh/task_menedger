<Window x:Class="task_menedger.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:task_menedger"
        mc:Ignorable="d"
        Title="MainWindow" Height="700" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Менеджер задач"
                   FontSize="18"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0 0 0 15"/>

        <Border Grid.Row="1"
                BorderBrush="Gray"
                BorderThickness="1"
                Padding="10"
                CornerRadius="5"
                Margin="0 0 0 10">
            <StackPanel>
                <TextBlock Text="Название задачи: "
                           Margin="0 0 0 5"/>
                
                <TextBox Name="TaskNameTB"
                         Height="30"
                         Margin="0 0 0 10"/>

                <TextBlock Text="Приоритет: "
                           Margin="0 0 0 5"/>

                <ComboBox Name="PriorityCmb"
                          Height="30"
                          Margin="0 0 0 15">
                    <ComboBoxItem Content="Высокий" IsSelected="True"/>
                    <ComboBoxItem Content="Средний"/>
                    <ComboBoxItem Content="Низкий"/>
                </ComboBox>

                <Button Name="AddBtn"
                        Content="Добавить"
                        Height="35"
                        Click="AddBtn_Click"/>
            </StackPanel>
        </Border>

        <TextBlock Text="Список задач"
                   Grid.Row="2"
                   FontWeight="Bold"
                   Margin="0 5"/>

        <ListBox Name="TaskLb"
                 Grid.Row="3"
                 Height="180"
                 Margin="0 5"
                 SelectionMode="Single"/>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0 10">
            <Button Name="CompleteBtn"
                    Content="Выполнено"
                    Width="150"
                    Height="35"
                    Margin="5"
                    Click="CompleteBtn_Click"/>
            <Button Name="DeleteBtn"
                    Content="Выполнено"
                    Width="150"
                    Height="35"
                    Margin="5"
                    Click="DeleteBtn_Click"/>
            <Button Name="SortBtn"
                    Content="Выполнено"
                    Width="150"
                    Height="35"
                    Margin="5"
                    Click="SortBtn_Click"/>
        </StackPanel>

        <Border Grid.Row="5"
                BorderBrush="Gray"
                BorderThickness="1"
                Padding="10"
                CornerRadius="5"
                Margin="0 10">
            <StackPanel>
                <TextBlock Text="Фильтр по приоритету: "
                           Margin="0 0 0 5"/>

                <StackPanel Orientation="Horizontal">
                    <RadioButton Name="FilterAllRbt"
                                 Content="Все"
                                 IsChecked="True"
                                 Margin="0 0 15 0"
                                 Click="FilterAllRbt_Click"/>
                    <RadioButton Name="FilterHighRbt"
                                 Content="Высокий"
                                 Margin="0 0 15 0"
                                 Click="FilterAllRbt_Click"/>
                    <RadioButton Name="FilterMediumRbt"
                                 Content="Средний"
                                 Margin="0 0 15 0"
                                 Click="FilterAllRbt_Click"/>
                    <RadioButton Name="FilterLowRbt"
                                 Content="Низкий"
                                 Margin="0 0 15 0"
                                 Click="FilterAllRbt_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="6"
                Background="LightGray"
                CornerRadius="5"
                Margin="0 10 0 0"
                Padding="5">
            <TextBlock Text="Всего: 0 | Выполнено: 0"
                       Name="CounterTb"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
